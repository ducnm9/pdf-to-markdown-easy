# ============================================================
# OCR PDF to Markdown — Configuration Example
# Copy this file to .env and fill in your values.
# ============================================================

# Base URL for the OpenAI-compatible LLM API endpoint.
# Examples:
#   Local LM Studio:  http://localhost:1234
#   Local Ollama:     http://localhost:11434
#   DeepSeek cloud:   https://api.deepseek.com
#   OpenAI:           https://api.openai.com
# Required.
LLM_BASE_URL=http://host.docker.internal:1234

# API key for authentication with the LLM provider.
# Leave empty for local servers that do not require authentication.
# Optional. Default: (empty)
LLM_API_KEY=your-api-key-here

# Model identifier to use for OCR and smart merge requests.
# Examples: deepseek-chat, gpt-4o, llava, mistral
# Required.
LLM_MODEL=google/gemma-4-e4b

# Maximum number of page OCR requests to run concurrently.
# Set to 1 for sequential processing (safest for rate-limited APIs).
# Increase for faster processing when the API allows parallel requests.
# Optional. Default: 1
MAX_CONCURRENCY=1

# Maximum number of retry attempts per failed OCR request.
# Retries use exponential backoff (2^attempt seconds between retries).
# Set to 0 to disable retries.
# Optional. Default: 3
MAX_RETRIES=3

# Enable LLM-based smart merge for the final Markdown output.
# When true, the merged page content is sent to the LLM with merge_prompt.txt
# for intelligent cleanup, deduplication, and formatting.
# When false, pages are concatenated with <!-- Page X --> separators.
# Optional. Default: false
SMART_MERGE=false

# Resolution (dots per inch) for PDF-to-image conversion.
# Higher values produce sharper images but increase processing time and memory.
# Recommended range: 150–400. Use 300 for most documents.
# Optional. Default: 300
IMAGE_DPI=300
